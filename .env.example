# Copy this to .env and fill in real values
POSTGRES_PASSWORD=change_me_strong_password
SECRET_KEY=change_me_flask_secret_64chars
JWT_SECRET_KEY=change_me_jwt_secret_64chars
# Include every browser origin you use (LAN IP counts as a different origin than localhost).
CORS_ORIGINS=http://localhost:6080,https://batchcraft.yourdomain.com
VITE_API_URL=http://localhost:6001

# Host ports (default frontend 6080 — port 6000 is blocked by Firefox as "unsafe")
HOST_FRONTEND_PORT=6080
HOST_BACKEND_PORT=6001
# If HOST_BACKEND_PORT is not 6001, set VITE_API_URL to http://localhost:<that port> for npm run dev against Docker.

# Postgres on the host (for local `backend/.venv` + `flask` CLI). Default 5433 avoids clashing with a local Postgres on 5432.
# After changing: docker compose up -d --force-recreate db
HOST_DB_PORT=5433
# Example for host-side Flask (NOT port 6001 — that is the HTTP API, not the database):
# DATABASE_URL=postgresql://batchcraft:YOUR_POSTGRES_PASSWORD@127.0.0.1:5433/batchcraft

# Optional: batch photo storage (defaults to backend/instance/uploads)
# BATCHCRAFT_UPLOAD_DIR=/var/batchcraft/uploads

# Optional: AI-assisted ingredient lookup (Add Ingredient → “Look up with AI”)
# With Docker: must be in this file — docker-compose passes it into the backend container.
# After changing: docker compose up -d --force-recreate backend
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
